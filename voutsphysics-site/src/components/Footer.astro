---
const year = new Date().getFullYear();
const calendly = 'https://calendly.com/voutsphysics/30min';
const facebook = 'https://www.facebook.com/profile.php?id=61578717674375';
const instagram = 'https://www.instagram.com/voutsphysics/';
---

<footer class="site-footer dark">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src="/images/logo.jpg" alt="VoutsPhysics" width="190" height="54" />
      <p class="footer-tag">Understand Physics. Perform with Confidence.</p>
    </div>

    <div class="footer-col">
      <h4>Explore</h4>
      <a href="/">Home</a>
      <a href="/about/">About</a>
      <a href="/services/">Services</a>
      <a href="/contact/">Contact</a>
    </div>

    <div class="footer-col">
      <h4>Get in touch</h4>
      <a href="tel:+306976900146">+30 697 690 0146</a>
      <a href="mailto:voutsphysics@gmail.com">voutsphysics@gmail.com</a>
      <span class="footer-loc">Athens, Greece &amp; Online</span>
      <a href={calendly} target="_blank" rel="noopener" class="footer-book">Book a free call &rarr;</a>
    </div>

    <div class="footer-col">
      <h4>Follow</h4>
      <a href={instagram} target="_blank" rel="noopener">Instagram</a>
      <a href={facebook} target="_blank" rel="noopener">Facebook</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {year} VoutsPhysics. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer { padding-top: var(--space-6); }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-5);
  }
  @media (min-width: 768px) {
    .footer-grid { grid-template-columns: 1.6fr 1fr 1.3fr 1fr; gap: var(--space-3); }
  }
  .footer-brand img { height: 50px; width: auto; border-radius: 8px; margin-bottom: 1rem; }
  .footer-tag { color: var(--on-dark-muted); max-width: 32ch; font-size: 0.98rem; }
  .footer-col { display: flex; flex-direction: column; gap: 0.6rem; }
  .footer-col h4 {
    color: #fff;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.3rem;
  }
  .footer-col a { color: var(--on-dark-muted); font-size: 0.98rem; }
  .footer-col a:hover { color: #fff; }
  .footer-loc { color: var(--on-dark-muted); font-size: 0.98rem; }
  .footer-book { color: var(--accent) !important; font-weight: 600; }
  .footer-book:hover { color: #fff !important; }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-block: 1.4rem;
  }
  .footer-bottom p { color: var(--on-dark-muted); font-size: 0.9rem; margin: 0; }
</style>
