---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  compact?: boolean;
}
const { eyebrow, title, subtitle, compact = false } = Astro.props;
---

<section class:list={['hero', 'dark', { compact }]}>
  <!-- Decorative wave + cradle motif (purely decorative) -->
  <svg class="hero-motif" viewBox="0 0 1200 400" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <g fill="none" stroke="#1B8A9C" stroke-width="1.2" opacity="0.35">
      <path d="M0 120 C 200 60, 400 180, 600 120 S 1000 60, 1200 120" />
      <path d="M0 160 C 220 100, 420 220, 640 150 S 1020 90, 1200 150" opacity="0.6" />
      <path d="M0 90 C 180 40, 380 150, 600 90 S 980 40, 1200 90" opacity="0.4" />
    </g>
    <g stroke="#2C5B8A" stroke-width="2" opacity="0.25" fill="none" stroke-linecap="round">
      <path d="M120 250 H 320" />
      <line x1="140" y1="250" x2="140" y2="320" />
      <line x1="180" y1="250" x2="180" y2="320" />
      <line x1="220" y1="250" x2="220" y2="320" />
      <line x1="260" y1="250" x2="260" y2="320" />
      <line x1="300" y1="250" x2="312" y2="320" />
    </g>
    <g fill="#2C7CC2" opacity="0.25">
      <circle cx="140" cy="330" r="9" />
      <circle cx="180" cy="330" r="9" />
      <circle cx="220" cy="330" r="9" />
      <circle cx="260" cy="330" r="9" />
      <circle cx="312" cy="330" r="9" />
    </g>
  </svg>

  <div class="container hero-content">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {subtitle && <p class="hero-sub">{subtitle}</p>}
    <slot />
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(160deg, var(--navy) 0%, var(--navy-soft) 100%);
    padding-block: clamp(3.5rem, 9vw, 7rem);
  }
  .hero.compact { padding-block: clamp(2.8rem, 6vw, 4.5rem); }
  .hero-motif {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .hero-content { position: relative; max-width: 760px; }
  .hero h1 { margin-bottom: 1rem; }
  .hero-sub {
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    color: var(--on-dark-muted);
    max-width: 56ch;
    margin-bottom: 1.8rem;
  }
  .hero-content :global(.hero-actions) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
</style>
