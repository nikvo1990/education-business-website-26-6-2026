---
const nav = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/services/', label: 'Services' },
  { href: '/contact/', label: 'Contact' },
];
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
const calendly = 'https://calendly.com/voutsphysics/30min';
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="VoutsPhysics — home">
      <img src="/images/logo.jpg" alt="VoutsPhysics" width="170" height="48" />
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
    <label for="nav-toggle" class="hamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav" aria-label="Main navigation">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href) }]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
      <a href={calendly} target="_blank" rel="noopener" class="btn btn-on-dark nav-cta">
        Book a Call
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--navy);
    position: sticky;
    top: 0;
    z-index: 50;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 68px;
    gap: 1rem;
  }
  .brand img {
    height: 44px;
    width: auto;
    border-radius: 6px;
  }
  .site-nav {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }
  .nav-link {
    color: var(--on-dark-muted);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.98rem;
    padding: 0.35rem 0;
    position: relative;
  }
  .nav-link:hover { color: #fff; }
  .nav-link.active { color: #fff; }
  .nav-link.active::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -4px;
    height: 2px;
    background: var(--accent);
    border-radius: 2px;
  }
  .nav-cta { padding: 0.6rem 1.2rem; }

  /* Hamburger (mobile only) */
  .hamburger { display: none; cursor: pointer; padding: 0.4rem; }
  .hamburger span {
    display: block;
    width: 26px;
    height: 2.5px;
    background: #fff;
    border-radius: 2px;
    margin: 5px 0;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-toggle { display: none; }

  @media (max-width: 767px) {
    .hamburger { display: block; }
    .site-nav {
      position: absolute;
      top: 68px;
      left: 0;
      right: 0;
      background: var(--navy);
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.5rem 1.25rem 1.25rem;
      border-top: 1px solid rgba(255,255,255,0.08);
      display: none;
    }
    .nav-toggle:checked ~ .site-nav { display: flex; }
    .nav-link { padding: 0.85rem 0; border-bottom: 1px solid rgba(255,255,255,0.07); }
    .nav-link.active::after { display: none; }
    .nav-cta { margin-top: 1rem; justify-content: center; }
    /* animate hamburger into an X */
    .nav-toggle:checked ~ .hamburger span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
    .nav-toggle:checked ~ .hamburger span:nth-child(2) { opacity: 0; }
    .nav-toggle:checked ~ .hamburger span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }
  }
</style>
